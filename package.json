{
  "name": "nadovibe-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "tsc -b --pretty false",
    "lint": "node scripts/lint-boundaries.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run typecheck && npm run lint && node --import tsx --test packages/core-kernel/test/*.test.ts",
    "test:e2e": "playwright test",
    "core:gate": "npm run test && npm run compose:config && npm run preflight:core && npm run ops:validate",
    "compose:config": "node infra/portainer/validate-stacks.mjs",
    "preflight:core": "node infra/portainer/core-stack/preflight.mjs --check-only",
    "ops:validate": "node --import tsx scripts/ops-validate.mjs",
    "durability:suite": "node --import tsx scripts/durability-suite.mjs",
    "failure:inject": "node scripts/failure-injection.mjs",
    "release:prepare": "node scripts/prepare-mounted-release.mjs",
    "release:deploy": "node scripts/deploy-mounted-release.mjs",
    "release:deploy:local": "node scripts/deploy-mounted-release.mjs --runtime-root .runtime --profile local"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@types/pg": "^8.20.0",
    "codemirror": "^6.0.2",
    "pg": "^8.20.0"
  }
}
